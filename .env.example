# -----------------------------------------------------------------------------
# Database Configuration
# -----------------------------------------------------------------------------
# Connection URL for Neon PostgreSQL or any other PostgreSQL instance.
# Example: postgresql://[user]:[password]@[host]/[database]?sslmode=require
DATABASE_URL="postgresql://neondb_owner:your_password@ep-cool-butterfly-a5z3p0.us-east-2.aws.neon.tech/neondb?sslmode=require"

# -----------------------------------------------------------------------------
# Authentication Config (Better Auth)
# -----------------------------------------------------------------------------
# Secret used for signing session keys. Keep this private and complex.
# You can generate one via: openssl rand -hex 32 or npx better-auth secret
BETTER_AUTH_SECRET="your_better_auth_secret_key_32_characters"

# The deployment URL of the Next.js application.
# Locally, this is http://localhost:3000. In production, use your Vercel deployment URL.
BETTER_AUTH_URL="http://localhost:3000"
